    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/dompurify": "^3.2.0",
    "@types/express": "^4.17.21",
    "@types/mysql": "^2.15.25",
    "@types/node": "^20.9.3",
    "@types/react": "^18.0.38",
    "@types/react-dom": "^18.2.16",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/ui": "4.0.18",
    "autoprefixer": "^10.4.17",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.24.0",
    "jsdom": "^27.4.0",
    "nodemon": "^3.0.1",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "tsup": "^8.5.1",
    "vite": "^7.0.0",
    "vitest": "^4.0.18"
  }
}